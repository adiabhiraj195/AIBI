# ============================================================
# AIBI Multi-Service Docker Compose Configuration
# This file defines environment variables for all services
# Copy to .env and fill in your actual values
# ============================================================

# ============================================================
# SHARED DATABASE CONFIGURATION
# Both backend services connect to the same PostgreSQL instance
# ============================================================
DB_HOST=database
DB_PORT=5432
DB_NAME=AIBI_Backend
DB_USER=AIBI_user
DB_PASSWORD=AIBI_password_change_me_in_production

# ============================================================
# REDIS CONFIGURATION
# Used by Main Brain for conversation memory and caching
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================
# LLM CONFIGURATION (For Main Brain)
# Requires API key for language model operations
# ============================================================
# LLM Provider: OpenRouter, OpenAI, Groq, or other compatible
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# ============================================================
# SUPABASE CONFIGURATION (For CSV Backend)
# Optional - used for file storage if configured
# ============================================================
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ============================================================
# GROQ API CONFIGURATION (For CSV Backend)
# Requires API key for AI-powered CSV analysis
# ============================================================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# ============================================================
# RAG SYSTEM CONFIGURATION (For Main Brain)
# ============================================================
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
MAX_RETRIEVAL_DOCS=10
SIMILARITY_THRESHOLD=0.7

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
DEBUG=false
LOG_LEVEL=INFO
VITE_DEBUG=false

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
# Points to the main RAG backend
VITE_API_URL=http://localhost:8000
# Points to the CSV processing backend
VITE_CSV_API_URL=http://localhost:8001
