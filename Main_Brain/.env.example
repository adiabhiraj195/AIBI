# ============================================================
# AIBI_Copilot_Main_Brain (Multi-Agent RAG) Environment Configuration
# CFO-Grade Financial Insights with Multi-Agent Orchestration
# ============================================================

# ============================================================
# FastAPI Configuration
# ============================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================
# SHARED DATABASE CONFIGURATION
# Connects to the same PostgreSQL database as CSV Backend (AIBI_Backend)
# When running in Docker: use hostname 'database'
# When running locally: use 'localhost' or your server IP
# ============================================================
DB_HOST=database
DB_PORT=5432
DB_NAME=AIBI_Backend
DB_USER=your_username
DB_PASSWORD=your_password
DB_SSL_MODE=disable

# ============================================================
# REDIS CONFIGURATION (For Conversation Memory)
# When running in Docker: use hostname 'redis'
# When running locally: use 'localhost'
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_USER=

# ============================================================
# LLM CONFIGURATION
# Supports OpenAI, OpenRouter, Groq, or other compatible APIs
# Get API key from your LLM provider dashboard
# ============================================================
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# ============================================================
# RAG SYSTEM CONFIGURATION
# Controls document retrieval and similarity matching
# ============================================================
EMBEDDING_MODEL=text-embedding-ada-002
MAX_RETRIEVAL_DOCS=10
SIMILARITY_THRESHOLD=0.7

# ============================================================
# AGENT CONFIGURATION
# ============================================================
MAX_RESPONSE_TIME=5.0
CONVERSATION_MEMORY_LIMIT=10
FOLLOW_UP_QUESTIONS_COUNT=4
RETRY_ATTEMPTS=3

# ============================================================
# SECURITY CONFIGURATION
# ============================================================
SECRET_KEY=your-secret-key-change-in-production
SESSION_TIMEOUT=3600
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ============================================================
# ENVIRONMENT INDICATOR
# ============================================================
ENVIRONMENT=development

MAX_RESPONSE_TIME=5.0
CONVERSATION_MEMORY_LIMIT=10
FOLLOW_UP_QUESTIONS_COUNT=4

# Security Configuration
SECRET_KEY=your-secret-key-here
SESSION_TIMEOUT=3600

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json