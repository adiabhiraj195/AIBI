		{
			"name": "Metadata & Knowledge Base",
			"item": [
				{
					"name": "Extract Column Info for Form",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test response status",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Save column info for metadata form",
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set(\"column_info\", JSON.stringify(jsonData.columns));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/metadata/extract/{{document_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"metadata",
								"extract",
								"{{document_id}}"
							]
						},
						"description": "Extract column information for frontend metadata form. This provides column names, data types, and sample data."
					}
				},
				{
					"name": "Save Complete Metadata",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate sample metadata based on extracted columns",
									"const columnInfo = pm.environment.get(\"column_info\");",
									"if (columnInfo) {",
									"    const columns = JSON.parse(columnInfo);",
									"    const enrichedColumns = columns.map((col, index) => ({",
									"        column_name: col.column_name,",
									"        data_type: col.data_type,",
									"        connection_key: index % 2 === 0 ? `conn_key_${index + 1}` : null,",
									"        alias: `alias_${col.column_name.toLowerCase().replace(/\\s+/g, '_')}`,",
									"        description: `This column represents ${col.column_name.toLowerCase()} data with ${col.data_type} values. Used for business analysis and reporting.`",
									"    }));",
									"    ",
									"    const payload = {",
									"        document_id: parseInt(pm.environment.get(\"document_id\")),",
									"        columns: enrichedColumns",
									"    };",
									"    ",
									"    pm.environment.set(\"metadata_payload\", JSON.stringify(payload));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"document_id\": {{document_id}},\n  \"columns\": [\n    {\n      \"column_name\": \"date\",\n      \"data_type\": \"date\",\n      \"connection_key\": \"date_key\",\n      \"alias\": \"transaction_date\",\n      \"description\": \"Date when the transaction occurred, used for temporal analysis and reporting\"\n    },\n    {\n      \"column_name\": \"amount\",\n      \"data_type\": \"float\",\n      \"connection_key\": null,\n      \"alias\": \"transaction_amount\",\n      \"description\": \"Monetary value of the transaction in USD, critical for financial analysis\"\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/metadata/save",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"metadata",
								"save"
							]
						},
						"description": "Save complete metadata with user-provided information. Update the request body with actual column data from your CSV."
					}
				},
