# ============================================================
# AIBI_Copilot_Frontend Environment Configuration
# React + Vite SPA for CFO Financial Intelligence Dashboard
# ============================================================

# ============================================================
# API CONFIGURATION
# Points to the backend services
# ============================================================
# Main RAG API (Multi-Agent Brain) - handles queries and conversations
VITE_API_URL=http://localhost:8000

# CSV Processing API - handles file uploads and analysis
VITE_CSV_API_URL=http://localhost:8001

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
# Enable debug mode for development
VITE_DEBUG=true

# Optional: Default user ID for demo/testing
VITE_DEFAULT_USER_ID=demo_user

